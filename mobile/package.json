{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.3.1",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "shared:build": "npm --prefix .. run contracts:build && npm --prefix .. run api-client:build",
    "eas-build-post-install": "cd .. && npm ci --workspace @cj/contracts --workspace @cj/api-client --include-workspace-root=false && npm run contracts:build && npm run api-client:build",
    "typecheck": "npm run shared:build && tsc --noEmit",
    "smoke:web": "npm run shared:build && expo export --platform web --output-dir dist",
    "web:routes:smoke": "node scripts/check-web-route-smoke.mjs",
    "smoke:true-service": "node scripts/app-true-service-smoke.mjs",
    "maestro:check": "node scripts/check-maestro-flows.mjs",
    "maestro:native": "node scripts/run-maestro-native.mjs",
    "maestro:native:dry-run": "node scripts/run-maestro-native.mjs --dry-run",
    "native:check": "node scripts/check-native-readiness.mjs",
    "native:check:strict": "node scripts/check-native-readiness.mjs --strict",
    "android:check": "node scripts/check-android-readiness.mjs",
    "android:check:strict": "node scripts/check-android-readiness.mjs --strict",
    "android:emulator:smoke": "node scripts/run-android-emulator-smoke.mjs",
    "android:app:smoke": "node scripts/run-android-app-smoke.mjs",
    "android:maestro:smoke": "node scripts/run-android-maestro-smoke.mjs",
    "device-discovery:check": "node scripts/check-device-discovery-parser.mjs",
    "eas-ios-release:smoke": "node scripts/run-eas-ios-release-smoke.mjs",
    "eas-android-release:smoke": "node scripts/run-eas-android-release-smoke.mjs",
    "physical-device:smoke": "node scripts/run-physical-device-smoke.mjs",
    "push-delivery:smoke": "node scripts/run-push-delivery-smoke.mjs",
    "native-crash:runtime:smoke": "node scripts/run-native-crash-runtime-smoke.mjs",
    "telemetry:runtime:smoke": "node scripts/run-telemetry-runtime-smoke.mjs",
    "native:upload:smoke": "node scripts/run-native-upload-smoke.mjs",
    "selected-media:upload:smoke": "node scripts/run-selected-media-upload-smoke.mjs",
    "accessibility:check": "node scripts/check-accessibility-contracts.mjs",
    "copy:check": "node scripts/check-user-copy-contracts.mjs",
    "routes:check": "node scripts/check-app-route-contracts.mjs",
    "features:check": "node scripts/check-app-feature-coverage-contracts.mjs",
    "true-service:check": "node scripts/check-app-true-service-smoke-contracts.mjs",
    "platform:check": "node scripts/check-platform-boundaries.mjs",
    "docs:check": "npm --prefix .. run docs:check",
    "docs:audit:dry-run:current": "npm --prefix .. run docs:audit:dry-run:current",
    "test": "npm run shared:build && jest --runInBand",
    "release:evidence:check": "node scripts/check-release-evidence.mjs",
    "release:evidence-redaction:check": "node scripts/check-release-evidence-redaction.mjs",
    "release:evidence-sanitization:check": "node scripts/check-release-evidence-sanitization.mjs",
    "release:db-parity:dry-run": "npm --prefix ../backend run ops:release-db:dry-run",
    "release:external-evidence:status": "node scripts/check-release-external-evidence-status.mjs",
    "release:external-evidence:status:contract": "node scripts/check-release-external-evidence-status-contract.mjs",
    "release:external-evidence:handoff:check": "node scripts/check-release-external-evidence-handoff.mjs",
    "release:external-evidence:handoff:contract": "node scripts/check-release-external-evidence-handoff-contract.mjs",
    "release:external-evidence:fixtures:check": "node scripts/check-release-completion-audit.mjs --fixture-contract",
    "release:external-evidence:dry-run": "npm run eas-ios-release:smoke -- --dry-run && npm run eas-android-release:smoke -- --dry-run && npm run physical-device:smoke -- --dry-run --platform=ios && npm run physical-device:smoke -- --dry-run --platform=android && npm run push-delivery:smoke -- --dry-run && npm run native-crash:runtime:smoke -- --dry-run && npm run telemetry:runtime:smoke -- --dry-run && npm run release:db-parity:dry-run",
    "release:external-evidence:signoff": "node scripts/run-release-external-evidence-signoff.mjs",
    "release:external-evidence:signoff:android-dry-run": "node scripts/run-release-external-evidence-signoff.mjs --dry-run --physical-platform=android",
    "release:external-evidence:validate": "node scripts/run-release-external-evidence-signoff.mjs --run --validate-only",
    "release:external-evidence:prereq-report:check": "node scripts/check-release-external-signoff-prerequisite-report.mjs",
    "release:external-evidence:workflow:check": "node scripts/check-release-external-signoff-workflow.mjs",
    "release:external-evidence:env-template:check": "node scripts/check-release-external-signoff-env-template.mjs",
    "release:external-evidence:input-status": "node scripts/check-release-external-signoff-input-status.mjs",
    "release:external-evidence:fill-inputs": "node scripts/fill-release-external-signoff-inputs.mjs",
    "release:external-evidence:github-secrets:check": "node scripts/check-release-github-secret-names.mjs",
    "release:external-evidence:github-secrets:strict": "node scripts/check-release-github-secret-names.mjs --strict",
    "release:external-evidence:github-secrets:sync": "node scripts/sync-release-github-secrets.mjs",
    "release:external-evidence:github-secrets:sync:contract": "node scripts/check-release-github-secret-sync-contract.mjs",
    "release:external-evidence:run": "node scripts/run-release-external-evidence-signoff.mjs --run",
    "release:completion:audit": "node scripts/check-release-completion-audit.mjs",
    "release:completion:audit:strict": "node scripts/check-release-completion-audit.mjs --strict",
    "release:completion:audit:contract": "node scripts/check-release-completion-audit-contract.mjs",
    "goal:completion:audit": "node scripts/check-app-goal-completion-audit.mjs",
    "goal:completion:audit:strict": "node scripts/check-app-goal-completion-audit.mjs --strict",
    "goal:completion:audit:contract": "node scripts/check-app-goal-audit-contract.mjs",
    "release:check": "npm run shared:build && node scripts/check-release-readiness.mjs",
    "release:preflight": "npm run test && npm run accessibility:check && npm run copy:check && npm run routes:check && npm run features:check && npm run true-service:check && npm run platform:check && npm run docs:check && npm run docs:audit:dry-run:current && npm run typecheck && npm run smoke:web && npm run web:routes:smoke && npm run maestro:check && npm run native:check && npm run android:check && npm run device-discovery:check && npm run release:evidence:check && npm run release:evidence-redaction:check && npm run release:evidence-sanitization:check && npm run release:external-evidence:status && npm run release:external-evidence:status:contract && npm run release:external-evidence:handoff:check && npm run release:external-evidence:handoff:contract && npm run release:external-evidence:fixtures:check && npm run release:external-evidence:dry-run && npm run release:external-evidence:signoff && npm run release:external-evidence:signoff:android-dry-run && npm run release:external-evidence:prereq-report:check && npm run release:external-evidence:workflow:check && npm run release:external-evidence:env-template:check && npm run release:external-evidence:input-status && npm run release:external-evidence:github-secrets:sync:contract && npm run release:completion:audit && npm run release:completion:audit:contract && npm run goal:completion:audit && npm run goal:completion:audit:contract && npm run release:check"
  },
  "dependencies": {
    "@cj/api-client": "file:../packages/api-client",
    "@cj/contracts": "file:../packages/contracts",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-modules-core": "55.0.25",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-web-browser": "~55.0.15",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
