generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUM 定義
enum Gender {
  male
  female
  other
  private
}

enum RelationshipStatus {
  single
  dating
  married
}

enum Language {
  zh
  en
}

enum Privacy {
  public
  partner_only
  private
}

enum PairingStatus {
  pending
  active
  cancelled
  temp
}

enum PairingType {
  normal
  quick
}

enum CaseStatus {
  draft
  submitted
  in_progress
  judgment_failed
  completed
  cancelled
}

enum CaseMode {
  remote
  collaborative
  quick
}

enum FileType {
  image
  video
  doc
}

enum PlanType {
  activity
  communication
  intimacy
  gift
  service
}

enum Difficulty {
  easy
  medium
  hard
}

enum ReconciliationIntent {
  repair
  cool_down
  graceful_exit
  safety_support
}

enum CommitmentStatus {
  not_viewed
  viewed
  deferred
  committed
  declined
  paused
}

enum RepairTrackStatus {
  draft
  partner_invited
  solo_active
  co_active
  replanning
  paused
  completed
  closed
}

enum RepairStepStatus {
  pending
  active
  done
  partial
  skipped
  adapted
}

enum RepairMode {
  solo
  co
}

enum RepairCheckInResult {
  done
  partial
  skipped
}

enum ClosenessLevel {
  closer
  same
  farther
}

enum StressLevel {
  low
  medium
  high
}

enum ExecutionAction {
  confirm
  checkin
  complete
  skip
}

enum ExecutionStatus {
  pending
  in_progress
  completed
  skipped
  failed
}

enum VerificationType {
  register
  reset_password
  verify_email
}

enum ContentType {
  article
  case_sample
  quiz
  tip
}

enum NotificationChannel {
  email
  push
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum AdminRoleKey {
  super_admin
  ops
  marketing
  support
}

enum CronRunStatus {
  running
  success
  failed
}

// v2.0: 心理畫像系統 ENUM
enum PsychDomain {
  attachment
  family_origin
  life_events
  belief_values
  cultural_background
  education_cognition
  personality
  relationship_history
}

enum InterviewStatus {
  in_progress
  processing
  completed
  processing_failed
  abandoned
}

enum InterviewTrigger {
  organic
  pre_case
  post_judgment
  onboarding
}

enum AIStreamPersistenceStatus {
  created
  queued
  started
  streaming
  completed
  persisted
  failed
  cancelled
}

enum InsightType {
  trait
  pattern
  belief
  trigger
  strength
  risk
  cultural
  developmental
}

enum ChatRoomStatus {
  solo_active
  invite_pending
  invite_accepted
  group_active
  judgment_requested
  judgment_completed
  judgment_failed
  archived
}

enum ChatHistoryVisibilityMode {
  share_full_history
  share_summary_only
  share_from_join_time
}

enum ChatParticipantType {
  user
  ai
  system
}

enum ChatRoleInRoom {
  roleA
  roleB
  aiMediator
  system
}

enum ChatMessageType {
  user_text
  ai_reflection
  ai_mediation
  ai_summary
  system_event
  safety_notice
}

enum ChatVisibilityScope {
  all
  owner_only
  summary_only
}

enum ChatInviteStatus {
  pending
  accepted
  declined
  expired
  revoked
}

// 模型定義
model User {
  id                   String              @id @default(uuid())
  email                String              @unique
  password_hash        String
  nickname             String?
  avatar_url           String?
  avatar_mime          String?
  gender               Gender?
  age                  Int?
  relationship_status  RelationshipStatus  @default(single)
  language             Language            @default(zh)
  timezone             String?
  notification_enabled Boolean             @default(true)
  privacy_level        Privacy             @default(private)
  last_login_at        DateTime?
  is_active            Boolean             @default(true)
  email_verified       Boolean             @default(false)
  login_failed_attempts Int                @default(0)
  locked_until         DateTime?
  token_version        Int                 @default(0)
  deleted_at           DateTime?
  created_by           String?
  updated_by           String?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  profile              UserProfile?
  cases_as_plaintiff   Case[]              @relation("PlaintiffCases")
  cases_as_defendant   Case[]              @relation("DefendantCases")
  evidences            Evidence[]
  execution_records    ExecutionRecord[]
  repair_participant_states RepairParticipantState[]
  repair_checkins      RepairCheckIn[]
  repair_track_events  RepairTrackEvent[]
  pairings_as_user1    Pairing[]           @relation("User1Pairings")
  pairings_as_user2    Pairing[]           @relation("User2Pairings")
  notifications        Notification[]

  // v2.0: 心理畫像
  psych_consent_given  Boolean             @default(false)
  psych_consent_at     DateTime?
  interview_sessions   InterviewSession[]
  profile_narratives   ProfileNarrative[]
  profile_insights     ProfileInsight[]
  profile_snapshots    ProfileSnapshot[]
  chat_rooms_owned     ChatRoom[]           @relation("ChatRoomOwner")
  chat_participants    ChatParticipant[]
  chat_invites_received ChatInvite[]        @relation("ChatInvitee")

  @@index([is_active])
  @@index([email_verified])
  @@map("users")
}

model AdminUser {
  id            String      @id @default(uuid())
  email         String      @unique
  password_hash String
  name          String
  role_id       String
  is_active     Boolean     @default(true)
  last_login_at DateTime?
  deleted_at    DateTime?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  role          AdminRole   @relation(fields: [role_id], references: [id], onDelete: Restrict)
  cron_run_logs CronRunLog[]

  @@index([role_id])
  @@index([is_active])
  @@map("admin_users")
}

model AdminRole {
  id          String      @id @default(uuid())
  key         AdminRoleKey @unique
  name        String
  description String?
  permissions Json
  is_system   Boolean     @default(true)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  admin_users AdminUser[]

  @@map("admin_roles")
}

model SystemConfig {
  id           String   @id @default(uuid())
  key          String   @unique
  value        Json
  description  String?
  is_sensitive Boolean  @default(false)
  is_runtime   Boolean  @default(true)
  updated_by   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([is_runtime])
  @@map("system_configs")
}

model CronRunLog {
  id                     String        @id @default(uuid())
  job_name               String        @db.VarChar(100)
  status                 CronRunStatus @default(running)
  started_at             DateTime      @default(now())
  finished_at            DateTime?
  duration_ms            Int?
  affected_count         Int?
  detail                 Json?
  triggered_by_admin_id  String?
  error_message          String?
  created_at             DateTime      @default(now())

  triggered_by_admin     AdminUser?    @relation(fields: [triggered_by_admin_id], references: [id], onDelete: SetNull)

  @@index([job_name, started_at])
  @@index([status, started_at])
  @@map("cron_run_logs")
}

/// v2.0: 下列個人資料欄位已被 ProfileNarrative / ProfileInsight 系統取代（按心理領域分析）。
/// 保留欄位以維持向後相容；新功能應透過 ProfileInsight 取得資料。
model UserProfile {
  id                        String   @id @default(uuid())
  user_id                   String   @unique
  /// @deprecated → ProfileInsight domain: education_cognition
  education_level           String?
  /// @deprecated → ProfileInsight domain: education_cognition
  major_field               String?
  /// @deprecated → ProfileInsight domain: education_cognition
  university                String?
  /// @deprecated → ProfileInsight domain: cultural_background
  ethnicity                 String?
  /// @deprecated → ProfileInsight domain: cultural_background
  cultural_identity         String[]
  /// @deprecated → ProfileInsight domain: family_origin
  upbringing_environment    String?
  /// @deprecated → ProfileInsight domain: belief_values
  religion                  String?
  /// @deprecated → ProfileInsight domain: belief_values
  religious_practice_level  String?
  /// @deprecated → ProfileInsight domain: family_origin
  family_structure          String?
  /// @deprecated → ProfileInsight domain: family_origin
  parents_relationship      String?
  /// @deprecated → ProfileInsight domain: family_origin
  family_economic_status    String?
  /// @deprecated → ProfileInsight domain: personality
  mbti_type                 String?
  /// @deprecated → ProfileInsight domain: personality
  big_five_personality      Json?
  /// @deprecated → ProfileInsight domain: personality
  communication_style       String?
  occupation                String?
  /// @deprecated → ProfileInsight domain: personality, belief_values
  interests                 String[]
  /// @deprecated → ProfileInsight domain: belief_values
  core_values               String[]
  profile_visibility        Privacy  @default(private)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  user                      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Pairing {
  id             String         @id @default(uuid())
  user1_id       String?
  user2_id       String?
  invite_code    String?        @unique @db.VarChar(6)
  status         PairingStatus  @default(pending)
  pairing_type   PairingType    @default(normal)
  session_id     String?        @db.VarChar(100)
  created_at     DateTime       @default(now())
  confirmed_at   DateTime?
  cancelled_at   DateTime?
  expires_at     DateTime?
  deleted_at     DateTime?
  created_by     String?
  updated_by     String?

  cases          Case[]
  user1          User?          @relation("User1Pairings", fields: [user1_id], references: [id])
  user2          User?          @relation("User2Pairings", fields: [user2_id], references: [id])
  quick_sessions QuickSession[]
  relationship_profile RelationshipProfile?

  @@index([user1_id])
  @@index([user2_id])
  @@index([status])
  @@index([expires_at])
  @@index([session_id])
  @@index([pairing_type])
  @@map("pairings")
}

model RelationshipProfile {
  id                               String   @id @default(uuid())
  pairing_id                       String   @unique
  relationship_duration_days       Int?
  relationship_stage               String?
  milestones                       Json?
  user1_location                   String?
  user2_location                   String?
  is_long_distance                 Boolean  @default(false)
  distance_km                      Int?
  meeting_frequency                String?
  user1_bottom_lines               String[]
  user2_bottom_lines               String[]
  common_bottom_lines              String[]
  historical_red_flags             Json?
  user1_preferences                Json?
  user2_preferences                Json?
  common_preferences               Json?
  dislikes                         Json?
  communication_frequency          String?
  preferred_communication_methods  String[]
  conflict_communication_style     String?
  relationship_strengths           String[]
  relationship_challenges          String[]
  historical_case_types            Json?
  historical_responsibility_trends Json?
  reconciliation_plan_execution_rate Float?
  relationship_improvement_trend   String?
  completion_percentage            Int       @default(0)
  last_updated_at                  DateTime  @default(now())
  created_at                       DateTime  @default(now())

  pairing                          Pairing   @relation(fields: [pairing_id], references: [id], onDelete: Cascade)

  @@map("relationship_profiles")
}

model Case {
  id                  String         @id @default(uuid())
  pairing_id          String
  title               String         @db.VarChar(200)
  type                String         @db.VarChar(50)
  sub_type            String?        @db.VarChar(50)
  plaintiff_id        String?
  defendant_id        String?
  plaintiff_statement String
  defendant_statement String?
  status              CaseStatus     @default(draft)
  judgment_failure_reason String?    @db.VarChar(500)
  mode                CaseMode       @default(remote)
  session_id          String?        @db.VarChar(100)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  submitted_at        DateTime?
  completed_at        DateTime?
  deleted_at          DateTime?
  safety_metadata     Json?
  created_by          String?
  updated_by          String?

  defendant           User?          @relation("DefendantCases", fields: [defendant_id], references: [id])
  pairing             Pairing        @relation(fields: [pairing_id], references: [id])
  plaintiff           User?          @relation("PlaintiffCases", fields: [plaintiff_id], references: [id])
  evidences           Evidence[]
  judgment            Judgment?
  quick_sessions      QuickSession[]
  case_content_links  CaseContentLink[]
  profile_snapshots   ProfileSnapshot[]
  chat_to_case_links  ChatToCaseLink[]

  @@index([pairing_id])
  @@index([plaintiff_id])
  @@index([defendant_id])
  @@index([status])
  @@index([type])
  @@index([created_at])
  @@index([submitted_at])
  @@index([mode])
  @@index([status, mode, created_at])
  @@map("cases")
}

model Evidence {
  id          String   @id @default(uuid())
  case_id     String
  user_id     String?
  file_url    String   @db.VarChar(500)
  mime_type   String?
  file_type   FileType
  file_size   Int
  checksum    String?
  description String?
  safety_metadata Json?
  created_at  DateTime @default(now())

  case        Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [user_id], references: [id])

  @@index([case_id])
  @@index([user_id])
  @@index([file_type])
  @@map("evidences")
}

model Judgment {
  id                   String               @id @default(uuid())
  case_id              String               @unique
  judgment_content     String
  summary              String?
  plaintiff_ratio      Float
  defendant_ratio      Float
  emotional_analysis   Json?
  ai_model             String               @default("gpt-3.5-turbo") @db.VarChar(50)
  prompt_version       String               @default("v1.0") @db.VarChar(20)
  user1_acceptance     Boolean?
  user2_acceptance     Boolean?
  user1_rating         Int?
  user2_rating         Int?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  case                 Case                 @relation(fields: [case_id], references: [id], onDelete: Cascade)
  reconciliation_plans ReconciliationPlan[]
  chat_to_case_links   ChatToCaseLink[]

  @@index([case_id])
  @@index([created_at])
  @@index([user1_acceptance])
  @@index([user2_acceptance])
  @@map("judgments")
}

model ReconciliationPlan {
  id                 String            @id @default(uuid())
  judgment_id        String
  intent             ReconciliationIntent @default(repair)
  version_group_id   String?
  superseded_at      DateTime?
  superseded_by_plan_id String?
  plan_content       String
  plan_type          PlanType
  difficulty_level   Difficulty
  estimated_duration Int?
  time_cost          Int
  money_cost         Int
  emotion_cost       Int
  skill_requirement  Int
  user1_selected     Boolean           @default(false)
  user2_selected     Boolean           @default(false)
  created_at         DateTime          @default(now())

  execution_records  ExecutionRecord[]
  judgment           Judgment          @relation(fields: [judgment_id], references: [id], onDelete: Cascade)
  repair_track       RepairTrack?

  @@index([judgment_id])
  @@index([intent])
  @@index([version_group_id])
  @@index([judgment_id, intent, superseded_at])
  @@index([difficulty_level])
  @@index([plan_type])
  @@map("reconciliation_plans")
}

model RepairTrack {
  id                String             @id @default(uuid())
  plan_id           String             @unique
  intent            ReconciliationIntent
  status            RepairTrackStatus  @default(draft)
  recommended_mode  RepairMode         @default(solo)
  current_step_index Int               @default(0)
  needs_replan      Boolean            @default(false)
  status_reason     String?
  closed_reason     String?
  last_closeness    ClosenessLevel?
  last_stress       StressLevel?
  last_needs_help   Boolean?
  last_replan_at    DateTime?
  partner_invited_at DateTime?
  started_at        DateTime?
  paused_at         DateTime?
  completed_at      DateTime?
  closed_at         DateTime?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  plan              ReconciliationPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  participant_states RepairParticipantState[]
  step_progresses   RepairStepProgress[]
  checkins          RepairCheckIn[]
  events            RepairTrackEvent[]

  @@index([status])
  @@index([intent])
  @@map("repair_tracks")
}

model RepairParticipantState {
  id                String            @id @default(uuid())
  repair_track_id   String
  user_id           String
  commitment_status CommitmentStatus  @default(not_viewed)
  response_reason   String?
  deferred_until    DateTime?
  last_notified_at  DateTime?
  responded_at      DateTime?
  invited_at        DateTime?
  viewed_at         DateTime?
  committed_at      DateTime?
  paused_at         DateTime?
  declined_at       DateTime?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  repair_track      RepairTrack       @relation(fields: [repair_track_id], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([repair_track_id, user_id])
  @@index([user_id, commitment_status])
  @@map("repair_participant_states")
}

model RepairStepProgress {
  id                String            @id @default(uuid())
  repair_track_id   String
  step_index        Int
  step_title        String
  step_content      String
  fallback_content  String?
  pause_rule        String?
  status            RepairStepStatus  @default(pending)
  completed_by      String?
  completed_at      DateTime?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  repair_track      RepairTrack       @relation(fields: [repair_track_id], references: [id], onDelete: Cascade)

  @@unique([repair_track_id, step_index])
  @@index([repair_track_id, status])
  @@map("repair_step_progresses")
}

model RepairCheckIn {
  id                String             @id @default(uuid())
  repair_track_id   String
  user_id           String
  step_index        Int
  result            RepairCheckInResult
  closeness         ClosenessLevel
  stress            StressLevel
  needs_help        Boolean            @default(false)
  notes             String?
  photos_urls       String[]
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  repair_track      RepairTrack        @relation(fields: [repair_track_id], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([repair_track_id, created_at])
  @@index([user_id, created_at])
  @@map("repair_checkins")
}

model RepairTrackEvent {
  id              String      @id @default(uuid())
  repair_track_id String
  user_id         String?
  event_type      String
  payload         Json?
  created_at      DateTime    @default(now())

  repair_track    RepairTrack @relation(fields: [repair_track_id], references: [id], onDelete: Cascade)
  user            User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([repair_track_id, created_at])
  @@index([event_type, created_at])
  @@map("repair_track_events")
}

model ExecutionRecord {
  id                     String             @id @default(uuid())
  reconciliation_plan_id String
  user_id                String
  action                 ExecutionAction
  status                 ExecutionStatus    @default(pending)
  notes                  String?
  photos_urls            String[]
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  reconciliation_plan    ReconciliationPlan @relation(fields: [reconciliation_plan_id], references: [id], onDelete: Cascade)
  user                   User               @relation(fields: [user_id], references: [id])

  @@index([reconciliation_plan_id])
  @@index([user_id])
  @@index([status])
  @@index([action])
  @@map("execution_records")
}

model QuickSession {
  id               String   @id @db.VarChar(100)
  pairing_id       String?
  case_id          String?
  session_data     Json?
  created_at       DateTime @default(now())
  expires_at       DateTime
  last_accessed_at DateTime @default(now())

  case             Case?    @relation(fields: [case_id], references: [id], onDelete: SetNull)
  pairing          Pairing? @relation(fields: [pairing_id], references: [id], onDelete: SetNull)

  @@index([expires_at])
  @@index([pairing_id])
  @@index([case_id])
  @@map("quick_sessions")
}

model ChatRoom {
  id                      String                    @id @default(uuid())
  status                  ChatRoomStatus            @default(solo_active)
  owner_user_id           String?
  session_id              String?                   @db.VarChar(100)
  history_visibility_mode ChatHistoryVisibilityMode @default(share_summary_only)
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @updatedAt

  owner                   User?                     @relation("ChatRoomOwner", fields: [owner_user_id], references: [id], onDelete: SetNull)
  participants            ChatParticipant[]
  messages                ChatMessage[]
  invites                 ChatInvite[]
  case_links              ChatToCaseLink[]

  @@index([owner_user_id])
  @@index([session_id])
  @@index([status, created_at])
  @@map("chat_rooms")
}

model ChatParticipant {
  id                        String              @id @default(uuid())
  room_id                   String
  participant_type          ChatParticipantType @default(user)
  user_id                   String?
  role_in_room              ChatRoleInRoom
  joined_at                 DateTime            @default(now())
  left_at                   DateTime?
  is_active                 Boolean             @default(true)

  room                      ChatRoom            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user                      User?               @relation(fields: [user_id], references: [id], onDelete: SetNull)
  sent_messages             ChatMessage[]
  sent_invites              ChatInvite[]        @relation("ChatInviteSender")
  triggered_case_links      ChatToCaseLink[]    @relation("ChatCaseTrigger")

  @@index([room_id, role_in_room])
  @@index([user_id])
  @@index([room_id, is_active])
  @@map("chat_participants")
}

model ChatMessage {
  id                        String              @id @default(uuid())
  room_id                   String
  sender_participant_id     String
  reply_to_message_id       String?
  content                   String
  message_type              ChatMessageType     @default(user_text)
  visibility_scope          ChatVisibilityScope @default(all)
  ai_strategy               String?
  ai_confidence             Float?
  safety_flag               Boolean             @default(false)
  safety_detail             String?
  created_at                DateTime            @default(now())

  room                      ChatRoom            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender_participant        ChatParticipant     @relation(fields: [sender_participant_id], references: [id], onDelete: Restrict)
  reply_to_message          ChatMessage?        @relation("ChatMessageReply", fields: [reply_to_message_id], references: [id], onDelete: SetNull)
  replies                   ChatMessage[]       @relation("ChatMessageReply")

  @@index([room_id, created_at])
  @@index([sender_participant_id])
  @@index([room_id, visibility_scope])
  @@index([reply_to_message_id])
  @@map("chat_messages")
}

model ChatInvite {
  id                        String            @id @default(uuid())
  room_id                   String
  inviter_participant_id    String
  invited_user_id           String?
  invite_code               String?           @unique @db.VarChar(12)
  status                    ChatInviteStatus  @default(pending)
  expires_at                DateTime?
  created_at                DateTime          @default(now())
  responded_at              DateTime?

  room                      ChatRoom          @relation(fields: [room_id], references: [id], onDelete: Cascade)
  inviter_participant       ChatParticipant   @relation("ChatInviteSender", fields: [inviter_participant_id], references: [id], onDelete: Restrict)
  invited_user              User?             @relation("ChatInvitee", fields: [invited_user_id], references: [id], onDelete: SetNull)

  @@index([room_id, status])
  @@index([invited_user_id, status])
  @@index([expires_at])
  @@map("chat_invites")
}

model ChatToCaseLink {
  id                           String            @id @default(uuid())
  room_id                      String
  case_id                      String
  judgment_id                  String?
  triggered_by_participant_id  String?
  conversion_snapshot          Json?
  created_at                   DateTime          @default(now())

  room                         ChatRoom          @relation(fields: [room_id], references: [id], onDelete: Cascade)
  case                         Case              @relation(fields: [case_id], references: [id], onDelete: Cascade)
  judgment                     Judgment?         @relation(fields: [judgment_id], references: [id], onDelete: SetNull)
  triggered_by_participant     ChatParticipant?  @relation("ChatCaseTrigger", fields: [triggered_by_participant_id], references: [id], onDelete: SetNull)

  @@index([room_id, created_at])
  @@index([case_id])
  @@index([judgment_id])
  @@index([triggered_by_participant_id])
  @@map("chat_to_case_links")
}

model EmailVerification {
  id         String            @id @default(uuid())
  email      String            @db.VarChar(255)
  code       String            @db.VarChar(6)
  type       VerificationType
  expires_at DateTime
  used       Boolean           @default(false)
  created_at DateTime          @default(now())

  @@index([email, type, used])
  @@index([code])
  @@index([expires_at])
  @@map("email_verifications")
}

model ContentItem {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(200)
  content     String
  content_type ContentType
  tags        String[]
  language    Language     @default(en)
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  case_links  CaseContentLink[]

  @@index([content_type])
  @@index([is_active])
  @@map("content_items")
}

model CaseContentLink {
  case_id    String
  content_id String
  relation   String    @default("recommend") @db.VarChar(30)
  created_at DateTime  @default(now())

  case       Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  content    ContentItem @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@id([case_id, content_id, relation])
  @@index([relation])
  @@map("case_content_links")
}

model Notification {
  id            String               @id @default(uuid())
  user_id       String
  channel       NotificationChannel
  template_code String               @db.VarChar(50)
  action_key    String?              @db.VarChar(50)
  priority      String?              @db.VarChar(20)
  group_key     String?              @db.VarChar(100)
  payload       Json?
  dedup_key     String?              @db.VarChar(100)
  sent_at       DateTime?
  read_at       DateTime?
  dismissed_at  DateTime?
  acted_at      DateTime?
  snoozed_until DateTime?
  status        NotificationStatus   @default(pending)
  error_message String?
  created_at    DateTime             @default(now())

  user          User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([user_id, read_at])
  @@index([user_id, dismissed_at])
  @@index([user_id, acted_at])
  @@index([user_id, snoozed_until])
  @@unique([dedup_key, template_code])
  @@map("notifications")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actor_id    String?
  actor_type  String?  @db.VarChar(20)
  entity_type String?  @db.VarChar(50)
  entity_id   String?
  action      String?  @db.VarChar(50)
  detail      Json?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id, created_at])
  @@map("audit_logs")
}

// v2.0: 心理畫像系統模型

model InterviewSession {
  id               String           @id @default(uuid())
  user_id          String
  status           InterviewStatus  @default(in_progress)
  trigger          InterviewTrigger @default(organic)
  ai_model_used    String?          @db.VarChar(50)
  total_user_words Int              @default(0)
  total_ai_words   Int              @default(0)
  domains_touched  PsychDomain[]    @default([])
  collected_facts  String[]         @default([])
  feedback_card    String?
  pipeline_step    Int              @default(0)
  started_at       DateTime?
  ended_at         DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  turns            InterviewTurn[]

  // 每用戶僅 1 個 in_progress：需在遷移中以 raw SQL 建立部分唯一索引
  // CREATE UNIQUE INDEX ux_interview_sessions_user_in_progress ON interview_sessions(user_id) WHERE status = 'in_progress';
  @@index([user_id, status])
  @@index([user_id, created_at])
  @@index([status, updated_at])
  @@map("interview_sessions")
}

model InterviewTurn {
  id                 String        @id @default(uuid())
  session_id         String
  turn_order         Int
  ai_message         String
  ai_intent          String?
  ai_target_domains  PsychDomain[]   @default([])
  extracted_facts    String[]        @default([])
  user_response      String?
  skipped            Boolean       @default(false)
  safety_flag        Boolean       @default(false)
  safety_detail      String?
  response_word_count Int?
  created_at         DateTime      @default(now())

  session            InterviewSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([session_id, turn_order], name: "ux_interview_turns_session_order")
  @@map("interview_turns")
}

model AIStreamSession {
  id              String                    @id @default(uuid())
  stream_id       String                    @unique
  request_id      String
  scope_type      String                    @db.VarChar(50)
  scope_id        String
  status          AIStreamPersistenceStatus
  last_seq        Int
  last_event_type String                    @db.VarChar(50)
  actor_role      String?                   @db.VarChar(50)
  text            String?
  phase           String?                   @db.VarChar(50)
  message_id      String?
  metadata        Json?
  error           Json?
  backend_mode    String?                   @db.VarChar(20)
  started_at      DateTime?
  completed_at    DateTime?
  persisted_at    DateTime?
  failed_at       DateTime?
  cancelled_at    DateTime?
  created_at      DateTime                  @default(now())
  updated_at      DateTime                  @updatedAt

  @@index([scope_type, scope_id, updated_at])
  @@index([request_id])
  @@index([status, updated_at])
  @@map("ai_stream_sessions")
}

model AIStreamEventRecord {
  id          String   @id @default(uuid())
  stream_id   String
  request_id  String
  scope_type  String   @db.VarChar(50)
  scope_id    String
  seq         Int
  event_type  String   @db.VarChar(50)
  actor_role  String?  @db.VarChar(50)
  message_id  String?
  delta_text  String?
  full_text   String?
  phase       String?  @db.VarChar(50)
  metadata    Json?
  error       Json?
  created_at  DateTime @default(now())

  @@unique([stream_id, seq], name: "ux_ai_stream_events_stream_seq")
  @@index([scope_type, scope_id, seq], map: "idx_ai_stream_events_scope_seq")
  @@index([event_type, created_at], map: "idx_ai_stream_events_type_created_at")
  @@map("ai_stream_events")
}

model AIStreamSessionArchive {
  id                String                    @id @default(uuid())
  archive_batch_key String                    @db.VarChar(100)
  stream_id         String                    @unique
  request_id        String
  scope_type        String                    @db.VarChar(50)
  scope_id          String
  status            AIStreamPersistenceStatus
  last_seq          Int
  last_event_type   String                    @db.VarChar(50)
  actor_role        String?                   @db.VarChar(50)
  text              String?
  phase             String?                   @db.VarChar(50)
  message_id        String?
  metadata          Json?
  error             Json?
  backend_mode      String?                   @db.VarChar(20)
  started_at        DateTime?
  completed_at      DateTime?
  persisted_at      DateTime?
  failed_at         DateTime?
  cancelled_at      DateTime?
  source_created_at DateTime
  source_updated_at DateTime
  archived_at       DateTime                  @default(now())

  @@index([archive_batch_key, archived_at], map: "idx_ai_stream_session_archives_batch_archived_at")
  @@index([scope_type, scope_id, source_updated_at], map: "idx_ai_stream_session_archives_scope_updated_at")
  @@index([status, source_updated_at], map: "idx_ai_stream_session_archives_status_updated_at")
  @@map("ai_stream_session_archives")
}

model AIStreamEventArchive {
  id                String   @id @default(uuid())
  archive_batch_key String   @db.VarChar(100)
  stream_id         String
  request_id        String
  scope_type        String   @db.VarChar(50)
  scope_id          String
  seq               Int
  event_type        String   @db.VarChar(50)
  actor_role        String?  @db.VarChar(50)
  message_id        String?
  delta_text        String?
  full_text         String?
  phase             String?  @db.VarChar(50)
  metadata          Json?
  error             Json?
  source_created_at DateTime
  archived_at       DateTime @default(now())

  @@unique([stream_id, seq], name: "ux_ai_stream_event_archives_stream_seq")
  @@index([archive_batch_key, archived_at], map: "idx_ai_stream_event_archives_batch_archived_at")
  @@index([scope_type, scope_id, seq], map: "idx_ai_stream_event_archives_scope_seq")
  @@index([event_type, source_created_at], map: "idx_ai_stream_event_archives_type_created_at")
  @@map("ai_stream_event_archives")
}

model ProfileNarrative {
  id              String      @id @default(uuid())
  user_id         String
  domain          PsychDomain
  raw_narrative   String
  ai_summary      String?
  word_count      Int         @default(0)
  // CHECK (completeness BETWEEN 0 AND 1) — 需在遷移中以 raw SQL 建立
  completeness    Float       @default(0)
  source_sessions String[]    @default([])
  is_latest       Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  insights        ProfileInsight[]

  @@index([user_id, domain, is_latest])
  // 每用戶每域僅 1 個 is_latest=true：需在遷移中以 raw SQL 建立部分唯一索引
  // CREATE UNIQUE INDEX ux_profile_narratives_user_domain_latest ON profile_narratives(user_id, domain) WHERE is_latest = true;
  @@map("profile_narratives")
}

model ProfileInsight {
  id            String      @id @default(uuid())
  user_id       String
  narrative_id  String?
  domain        PsychDomain
  insight_type  InsightType
  key           String      @db.VarChar(100)
  value         String
  // CHECK (confidence BETWEEN 0 AND 1) — 需在遷移中以 raw SQL 建立
  confidence    Float       @default(0.5)
  evidence      String?
  clinical_note String?
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  user          User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  narrative     ProfileNarrative? @relation(fields: [narrative_id], references: [id], onDelete: SetNull)

  @@index([user_id, domain, is_active])
  @@index([user_id, key, is_active])
  @@index([user_id, is_active, confidence])
  @@map("profile_insights")
}

model ProfileSnapshot {
  id              String   @id @default(uuid())
  user_id         String
  case_id         String
  snapshot_data   Json
  // CHECK (richness_score BETWEEN 0 AND 1) — 需在遷移中以 raw SQL 建立
  richness_score  Float    @default(0)
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  case            Case     @relation(fields: [case_id], references: [id], onDelete: Restrict)

  @@unique([case_id, user_id])
  @@index([user_id])
  @@map("profile_snapshots")
}
