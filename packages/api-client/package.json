{
  "name": "@emorapy/api-client",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./types/*.d.ts",
      "import": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "types",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:m1": "npm run build && node tests/m1.test.mjs",
    "test:m2": "npm run build && node tests/m2.test.mjs",
    "test:m3": "npm run build && node tests/m3.test.mjs",
    "test:m4": "npm run build && node tests/m4.test.mjs",
    "test:m5": "npm run build && node tests/m5.test.mjs",
    "test:ai-stream-state": "npm run build && node tests/aiStreamState.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@emorapy/contracts": "1.5.0"
  },
  "devDependencies": {
    "axios": "^1.13.2",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "axios": "^1.13.2"
  }
}
