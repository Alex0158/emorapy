# 熊媽媽法庭 - 後端環境變量配置示例
# 複製此文件為 .env 並填入實際值

# ============================================
# 服務器配置
# ============================================
# 服務器端口（默認: 3001，本地避免與前端衝突）
PORT=3001

# 運行環境: development | production | test
NODE_ENV=development

# ============================================
# 數據庫配置（必需）
# ============================================
# PostgreSQL 連接字符串
# 格式: postgresql://用戶名:密碼@主機:端口/數據庫名?參數
# 示例（Docker 開發）: postgresql://mbc:mbc_dev_pass@localhost:55432/mbc_dev
DATABASE_URL=postgresql://mbc:mbc_dev_pass@localhost:55432/mbc_dev

# 測試環境可選用 SQLite（降低依賴）
# TEST_USE_SQLITE=true
# TEST_SQLITE_URL=file:./tmp/test.db

# ============================================
# JWT 認證配置（必需）
# ============================================
# JWT 簽名密鑰（建議使用強隨機字符串，至少32字符）
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# JWT 過期時間（默認: 7d）
# 格式: 數字+單位 (如: 7d, 24h, 60m, 3600s)
JWT_EXPIRES_IN=7d

# ============================================
# OpenAI API 配置（必需）
# ============================================
# OpenAI API 密鑰（格式: sk-...）
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI 模型（默認: gpt-3.5-turbo）
OPENAI_MODEL=gpt-3.5-turbo

# 最大 Token 數（默認: 2000，範圍: 1-4000）
OPENAI_MAX_TOKENS=2000

# 每日調用限制（默認: 1000）
OPENAI_DAILY_LIMIT=1000

# ============================================
# 郵件服務配置（可選）
# ============================================
# SMTP 服務器主機
# SMTP_HOST=smtp.gmail.com

# SMTP 端口（默認: 587）
# SMTP_PORT=587

# SMTP 用戶名（郵箱地址）
# SMTP_USER=your-email@gmail.com

# SMTP 密碼（應用專用密碼）
# SMTP_PASS=your-app-specific-password

# ============================================
# 文件存儲配置
# ============================================
# 文件上傳目錄（默認: ./uploads）
UPLOAD_DIR=./uploads

# 最大文件大小（字節，默認: 5MB = 5242880）
MAX_FILE_SIZE=5242880

# CDN URL（生產環境，可選）
# CDN_URL=https://cdn.yourdomain.com

# ============================================
# 前端配置
# ============================================
# 前端 URL（用於 CORS 和重定向）
# 開發環境: http://localhost:5173
# 生產環境: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# 文件訪問基礎 URL（用於返回上傳文件的可訪問地址，默認 http://localhost:3000）
FILE_BASE_URL=http://localhost:3000

# 允許的來源（CORS，多個用逗號分隔）
# 開發環境: http://localhost:5173
# 生產環境: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# 可選：上傳訪問 IP 黑名單（逗號分隔，精確匹配 req.ip）
# BLACKLIST_IPS=

# ============================================
# 數據庫遷移配置（可選）
# ============================================
# 是否自動運行遷移（默認: true）
# 設置為 false 可禁用自動遷移
# RUN_MIGRATIONS=true

# ============================================
# 其他開關（布林值請僅用 true/false 小寫）
# ============================================
# 允許公共上傳（僅限開發/測試，生產會被強制禁用）
# ALLOW_PUBLIC_UPLOADS=false
# 允許降級為簡單鎖（無 Redis）
# ALLOW_SIMPLE_LOCK=false
# 跳過 DB 初始化（僅供測試流程）
# SKIP_DB_INIT=false

# ============================================
# Redis 配置（可選，用於分布式鎖與緩存）
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# 日誌配置（可選）
# ============================================
# 日誌級別: error | warn | info | debug
# 開發環境建議: debug
# 生產環境建議: info
# LOG_LEVEL=debug
