# App release external signoff environment template.
# Copy to a local untracked file before filling values. Do not commit real secrets.

# Local runner mode and report output.
DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
APP_RELEASE_EXTERNAL_SIGNOFF_RUN=false
APP_RELEASE_EXTERNAL_SIGNOFF_REPORT_DIR=/tmp/cj-app-signoff
APP_PHYSICAL_DEVICE_PLATFORM=ios
APP_EAS_IOS_REQUIRE_TESTFLIGHT=true

# EAS / Expo.
EXPO_TOKEN=REPLACE_WITH_EXPO_ACCESS_TOKEN

# Apple submission and App Store Connect lookup.
ASC_APPLE_ID=REPLACE_WITH_APPLE_ID_EMAIL
EXPO_APPLE_APP_SPECIFIC_PASSWORD=REPLACE_WITH_APPLE_APP_SPECIFIC_PASSWORD
APP_STORE_CONNECT_ISSUER_ID=REPLACE_WITH_ASC_ISSUER_ID
APP_STORE_CONNECT_KEY_ID=REPLACE_WITH_ASC_KEY_ID
APP_STORE_CONNECT_PRIVATE_KEY_PATH=REPLACE_WITH_ABSOLUTE_PATH_TO_ASC_PRIVATE_KEY_P8
APP_STORE_CONNECT_APP_ID=REPLACE_WITH_OPTIONAL_ASC_APP_ID

# Physical device smoke inputs.
APP_IOS_DEVICE_UDID=REPLACE_WITH_TRUSTED_PHYSICAL_IOS_DEVICE_UDID
APP_IOS_DEVICE_APP_PATH=REPLACE_WITH_ABSOLUTE_PATH_TO_SIGNED_APP_BUNDLE
APP_ANDROID_DEVICE_SERIAL=REPLACE_WITH_TRUSTED_PHYSICAL_ANDROID_DEVICE_SERIAL

# Push provider delivery.
APP_PUSH_DELIVERY_EXPO_PUSH_TOKEN=REPLACE_WITH_EXPO_PUSH_TOKEN_FROM_INSTALLED_APP
APP_PUSH_DELIVERY_ACCESS_TOKEN=REPLACE_WITH_OPTIONAL_EXPO_PUSH_ACCESS_TOKEN

# Native crash runtime lookup.
APP_SENTRY_ORG=REPLACE_WITH_SENTRY_ORG
APP_SENTRY_PROJECT=REPLACE_WITH_SENTRY_PROJECT
APP_SENTRY_AUTH_TOKEN=REPLACE_WITH_SENTRY_AUTH_TOKEN
APP_NATIVE_CRASH_SENTRY_EVENT_ID=REPLACE_WITH_CONTROLLED_NATIVE_CRASH_EVENT_ID
APP_NATIVE_CRASH_EXPECTED_ENVIRONMENT=production

# App telemetry runtime ingest evidence refresh.
APP_TELEMETRY_RUNTIME_API_BASE_URL=REPLACE_WITH_RELEASE_API_BASE_URL

# Release / production DB parity evidence refresh.
DATABASE_URL=REPLACE_WITH_RELEASE_OR_PRODUCTION_POSTGRES_URL
