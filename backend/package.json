{
  "name": "cj-platform-backend",
  "version": "1.3.4",
  "description": "Emorapy 後端服務",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:railway": "railway run -e staging -- node scripts/dev-railway.cjs",
    "dev:railway:staging": "railway run -e staging -- node scripts/dev-railway.cjs",
    "dev:railway:production": "ALLOW_REMOTE_PRODUCTION_ENV=true railway run -e production -- node scripts/dev-railway.cjs",
    "dev:postgres:up": "docker compose -f docker-compose.postgres.yml up -d",
    "dev:postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "dev:postgres:logs": "docker compose -f docker-compose.postgres.yml logs -f postgres",
    "dev:redis:up": "docker compose -f docker-compose.redis.yml up -d",
    "dev:redis:down": "docker compose -f docker-compose.redis.yml down",
    "dev:redis:logs": "docker compose -f docker-compose.redis.yml logs -f redis",
    "build:contracts": "node ./node_modules/typescript/bin/tsc -p ../packages/contracts/tsconfig.json",
    "prebuild": "npm run build:contracts",
    "build": "tsc",
    "prebuild:prod": "npm run build:contracts",
    "build:prod": "tsc --project tsconfig.prod.json",
    "start": "node dist/index.js",
    "pretest": "npm run build:contracts",
    "test": "jest",
    "pretest:unit": "npm run build:contracts",
    "test:unit": "jest --testPathPatterns=tests/unit --runInBand",
    "pretest:integration": "npm run build:contracts",
    "test:integration": "jest --testPathPatterns=tests/integration --runInBand",
    "test:integration:ai-stream-redis": "jest --runInBand tests/integration/ai-stream-redis.integration.test.ts",
    "test:integration:verbose": "jest --testPathPatterns=tests/integration --verbose --runInBand",
    "test:integration:flow": "RUN_FLOW_TESTS=true jest tests/integration/quick-experience.flow.test.ts --runInBand",
    "test:flow": "jest --testPathPattern=flow.test.ts --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "bench:admin:jobs-stats": "tsx scripts/benchmark-admin-job-stats.ts",
    "bench:chat:judgment-concurrency": "tsx scripts/benchmark-chat-judgment-concurrency.ts",
    "bench:chat:invite-accept-concurrency": "tsx scripts/benchmark-chat-invite-accept-concurrency.ts",
    "bench:chat:concurrency-gate": "tsx scripts/benchmark-chat-concurrency-gate.ts",
    "precheck:chat:active-roles-uniqueness": "tsx scripts/precheck-chat-active-roles-uniqueness.ts",
    "precheck:pairing:normal-uniqueness": "tsx scripts/precheck-pairing-normal-uniqueness.ts",
    "plan-fix:chat:active-roles-uniqueness": "tsx scripts/plan-fix-chat-active-roles-uniqueness.ts",
    "ops:alerts:check": "tsx scripts/check-alerts.ts",
    "ops:migration:report": "tsx scripts/report-prisma-migrations.ts",
    "ops:cost:snapshot": "tsx scripts/cost-snapshot.ts",
    "ops:product-state:audit": "tsx scripts/audit-product-state-consistency.ts",
    "ops:product-state:audit:persist": "tsx scripts/audit-product-state-consistency.ts --persist",
    "ops:ai-pricing:check": "tsx scripts/check-ai-pricing-catalog.ts",
    "ops:release-db:check": "tsx scripts/check-release-db-parity.ts",
    "ops:release-db:dry-run": "tsx scripts/check-release-db-parity.ts --dry-run --target=release --require-release-target",
    "ops:release-db:evidence": "tsx scripts/check-release-db-parity.ts --target=release --require-release-target --evidence-dir=../docs/核心開發文件/90-證據與盤點/環境與發版驗證",
    "ops:smoke-accounts:check": "tsx scripts/check-smoke-account-hygiene.ts",
    "web:p0:true-service:smoke": "tsx scripts/web-p0-true-service-smoke.ts",
    "lint": "biome lint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "postinstall": "npm run build"
  },
  "keywords": [
    "court",
    "relationship",
    "ai",
    "judgment"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "openai": "^4.20.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.33.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "jest": "^30.2.0",
    "prettier": "^3.1.0",
    "prisma": "^5.7.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "brace-expansion": "2.0.3",
    "jest-util": {
      "picomatch": "4.0.4"
    },
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "path-to-regexp": "0.1.13",
    "picomatch": "2.3.2"
  }
}
