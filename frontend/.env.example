# Emorapy - 前端環境變量配置示例
# 複製此文件為 .env 並填入實際值
# 注意：Vite 要求環境變量以 VITE_ 開頭

# ============================================
# API 配置（必需）
# ============================================
# 後端 API 基礎 URL
# 開發環境: http://localhost:3001/api/v1
# 生產環境: https://your-backend-domain.com/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1

# 管理後台入口（主前台點擊「運維台」會跳轉此地址）
# 本地示例: http://localhost:5174/admin/login
# 生產示例: https://admin.your-domain.com/admin/login
# 注意：主前台必須填「絕對 URL」，不可使用 /admin/login 相對路徑（避免重導循環）
VITE_ADMIN_LOGIN_URL=http://localhost:5175/admin/login

# ============================================
# 應用配置（可選）
# ============================================
# 應用標題（默認: Emorapy）
# VITE_APP_TITLE=Emorapy

# 應用描述（默認: 大愛、包容、保護、呵護，為您的關係提供公正溫暖的判決。）
# VITE_APP_DESCRIPTION=大愛、包容、保護、呵護，為您的關係提供公正溫暖的判決。

# ============================================
# 監控和分析（可選）
# ============================================
# Google Analytics 追蹤 ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN（錯誤追蹤）
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================
# 功能開關（可選）
# ============================================
# 是否啟用調試模式（默認: false）
# 開發環境會自動啟用
# VITE_DEBUG=false

# ============================================
# 開發環境說明
# ============================================
# 1. 複製此文件為 .env
# 2. 根據實際環境修改配置值
# 3. 重啟開發服務器使配置生效
# 
# 注意：
# - 所有環境變量必須以 VITE_ 開頭才能在代碼中訪問
# - 修改 .env 文件後需要重啟開發服務器
# - 不要將 .env 文件提交到版本控制系統
