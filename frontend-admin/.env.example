# CJ 平台 - Admin 前端環境變量配置示例

# 後端 API 基礎 URL
VITE_API_BASE_URL=http://localhost:3001/api/v1

# 客戶前端網址（用於版本資訊顯示，可選）
# 本地示例: http://localhost:5173
# 生產示例: https://mother-bear-court.vercel.app
# VITE_FRONTEND_BASE_URL=http://localhost:5173

# Admin 401 跳轉地址
# 建議填絕對 URL，避免環境切換時出現錯誤跳轉
# 本地示例: http://localhost:5174/admin/login
# 生產示例: https://admin.your-domain.com/admin/login
VITE_ADMIN_LOGIN_URL=http://localhost:5174/admin/login
