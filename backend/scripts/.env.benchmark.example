# ============================================
# Chat Benchmark / Gate Environment Template
# ============================================

# Shared
API_BASE_URL=http://localhost:3001/api/v1
# BURST_SIZE upper bound: 200
BURST_SIZE=20
# REQUEST_TIMEOUT_MS range: [1000, 120000]
REQUEST_TIMEOUT_MS=15000
DRY_RUN=true
REPORT_PATH=./tmp/bench-reports/manual-report.json

# Judgment concurrency benchmark
# Use one of AUTH_TOKEN or SESSION_ID.
AUTH_TOKEN=
SESSION_ID=
HISTORY_VISIBILITY_MODE=share_summary_only
MESSAGE_CONTENT=昨天又發生爭執，我希望得到具體判決建議。
# STATUS_POLL_TIMES range: [1, 120]
STATUS_POLL_TIMES=15
# STATUS_POLL_INTERVAL_MS range: [200, 60000]
STATUS_POLL_INTERVAL_MS=1000

# Invite-accept concurrency benchmark
OWNER_AUTH_TOKEN=
INVITEE_TOKENS=tokenA,tokenB,tokenC
# EXPIRES_IN_HOURS range: [1, 168]
EXPIRES_IN_HOURS=24

# Gate script options
GATE_RUN_JUDGMENT=true
GATE_RUN_INVITE_ACCEPT=true
GATE_REPORT_DIR=./tmp/bench-reports
GATE_REPORT_PATH=./tmp/bench-reports/chat-concurrency-gate-report.json

# Migration rehearsal artifacts
PRECHECK_REPORT_PATH=./tmp/bench-reports/chat-active-roles-precheck.json
FIX_PLAN_OUTPUT_PATH=./tmp/bench-reports/chat-active-roles-fix-plan.sql
FIX_PLAN_REPORT_PATH=./tmp/bench-reports/chat-active-roles-fix-plan.json
