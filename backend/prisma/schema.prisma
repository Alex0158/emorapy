generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUM 定義
enum Gender {
  male
  female
  other
  private
}

enum RelationshipStatus {
  single
  dating
  married
}

enum Language {
  zh
  en
}

enum Privacy {
  public
  partner_only
  private
}

enum PairingStatus {
  pending
  active
  cancelled
  temp
}

enum PairingType {
  normal
  quick
}

enum CaseStatus {
  draft
  submitted
  in_progress
  judgment_failed
  completed
  cancelled
}

enum CaseMode {
  remote
  collaborative
  quick
}

enum FileType {
  image
  video
  doc
}

enum PlanType {
  activity
  communication
  intimacy
  gift
  service
}

enum Difficulty {
  easy
  medium
  hard
}

enum ExecutionAction {
  confirm
  checkin
  complete
  skip
}

enum ExecutionStatus {
  pending
  in_progress
  completed
  skipped
  failed
}

enum VerificationType {
  register
  reset_password
  verify_email
}

enum ContentType {
  article
  case_sample
  quiz
  tip
}

enum NotificationChannel {
  email
  push
}

enum NotificationStatus {
  pending
  sent
  failed
}

// v2.0: 心理畫像系統 ENUM
enum PsychDomain {
  attachment
  family_origin
  life_events
  belief_values
  cultural_background
  education_cognition
  personality
  relationship_history
}

enum InterviewStatus {
  in_progress
  processing
  completed
  processing_failed
  abandoned
}

enum InterviewTrigger {
  organic
  pre_case
  post_judgment
  onboarding
}

enum InsightType {
  trait
  pattern
  belief
  trigger
  strength
  risk
  cultural
  developmental
}

// 模型定義
model User {
  id                   String              @id @default(uuid())
  email                String              @unique
  password_hash        String
  nickname             String?
  avatar_url           String?
  avatar_mime          String?
  gender               Gender?
  age                  Int?
  relationship_status  RelationshipStatus  @default(single)
  language             Language            @default(zh)
  timezone             String?
  notification_enabled Boolean             @default(true)
  privacy_level        Privacy             @default(private)
  last_login_at        DateTime?
  is_active            Boolean             @default(true)
  email_verified       Boolean             @default(false)
  login_failed_attempts Int                @default(0)
  locked_until         DateTime?
  token_version        Int                 @default(0)
  deleted_at           DateTime?
  created_by           String?
  updated_by           String?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  profile              UserProfile?
  cases_as_plaintiff   Case[]              @relation("PlaintiffCases")
  cases_as_defendant   Case[]              @relation("DefendantCases")
  evidences            Evidence[]
  execution_records    ExecutionRecord[]
  pairings_as_user1    Pairing[]           @relation("User1Pairings")
  pairings_as_user2    Pairing[]           @relation("User2Pairings")
  notifications        Notification[]

  // v2.0: 心理畫像
  psych_consent_given  Boolean             @default(false)
  psych_consent_at     DateTime?
  interview_sessions   InterviewSession[]
  profile_narratives   ProfileNarrative[]
  profile_insights     ProfileInsight[]
  profile_snapshots    ProfileSnapshot[]

  @@index([is_active])
  @@index([email_verified])
  @@map("users")
}

/// v2.0: 下列個人資料欄位已被 ProfileNarrative / ProfileInsight 系統取代（按心理領域分析）。
/// 保留欄位以維持向後相容；新功能應透過 ProfileInsight 取得資料。
model UserProfile {
  id                        String   @id @default(uuid())
  user_id                   String   @unique
  /// @deprecated → ProfileInsight domain: education_cognition
  education_level           String?
  /// @deprecated → ProfileInsight domain: education_cognition
  major_field               String?
  /// @deprecated → ProfileInsight domain: education_cognition
  university                String?
  /// @deprecated → ProfileInsight domain: cultural_background
  ethnicity                 String?
  /// @deprecated → ProfileInsight domain: cultural_background
  cultural_identity         String[]
  /// @deprecated → ProfileInsight domain: family_origin
  upbringing_environment    String?
  /// @deprecated → ProfileInsight domain: belief_values
  religion                  String?
  /// @deprecated → ProfileInsight domain: belief_values
  religious_practice_level  String?
  /// @deprecated → ProfileInsight domain: family_origin
  family_structure          String?
  /// @deprecated → ProfileInsight domain: family_origin
  parents_relationship      String?
  /// @deprecated → ProfileInsight domain: family_origin
  family_economic_status    String?
  /// @deprecated → ProfileInsight domain: personality
  mbti_type                 String?
  /// @deprecated → ProfileInsight domain: personality
  big_five_personality      Json?
  /// @deprecated → ProfileInsight domain: personality
  communication_style       String?
  occupation                String?
  /// @deprecated → ProfileInsight domain: personality, belief_values
  interests                 String[]
  /// @deprecated → ProfileInsight domain: belief_values
  core_values               String[]
  profile_visibility        Privacy  @default(private)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  user                      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Pairing {
  id             String         @id @default(uuid())
  user1_id       String?
  user2_id       String?
  invite_code    String?        @unique @db.VarChar(6)
  status         PairingStatus  @default(pending)
  pairing_type   PairingType    @default(normal)
  session_id     String?        @db.VarChar(100)
  created_at     DateTime       @default(now())
  confirmed_at   DateTime?
  cancelled_at   DateTime?
  expires_at     DateTime?
  deleted_at     DateTime?
  created_by     String?
  updated_by     String?

  cases          Case[]
  user1          User?          @relation("User1Pairings", fields: [user1_id], references: [id])
  user2          User?          @relation("User2Pairings", fields: [user2_id], references: [id])
  quick_sessions QuickSession[]
  relationship_profile RelationshipProfile?

  @@index([user1_id])
  @@index([user2_id])
  @@index([status])
  @@index([expires_at])
  @@index([session_id])
  @@index([pairing_type])
  @@map("pairings")
}

model RelationshipProfile {
  id                               String   @id @default(uuid())
  pairing_id                       String   @unique
  relationship_duration_days       Int?
  relationship_stage               String?
  milestones                       Json?
  user1_location                   String?
  user2_location                   String?
  is_long_distance                 Boolean  @default(false)
  distance_km                      Int?
  meeting_frequency                String?
  user1_bottom_lines               String[]
  user2_bottom_lines               String[]
  common_bottom_lines              String[]
  historical_red_flags             Json?
  user1_preferences                Json?
  user2_preferences                Json?
  common_preferences               Json?
  dislikes                         Json?
  communication_frequency          String?
  preferred_communication_methods  String[]
  conflict_communication_style     String?
  relationship_strengths           String[]
  relationship_challenges          String[]
  historical_case_types            Json?
  historical_responsibility_trends Json?
  reconciliation_plan_execution_rate Float?
  relationship_improvement_trend   String?
  completion_percentage            Int       @default(0)
  last_updated_at                  DateTime  @default(now())
  created_at                       DateTime  @default(now())

  pairing                          Pairing   @relation(fields: [pairing_id], references: [id], onDelete: Cascade)

  @@map("relationship_profiles")
}

model Case {
  id                  String         @id @default(uuid())
  pairing_id          String
  title               String         @db.VarChar(200)
  type                String         @db.VarChar(50)
  sub_type            String?        @db.VarChar(50)
  plaintiff_id        String?
  defendant_id        String?
  plaintiff_statement String
  defendant_statement String?
  status              CaseStatus     @default(draft)
  judgment_failure_reason String?    @db.VarChar(500)
  mode                CaseMode       @default(remote)
  session_id          String?        @db.VarChar(100)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  submitted_at        DateTime?
  completed_at        DateTime?
  deleted_at          DateTime?
  created_by          String?
  updated_by          String?

  defendant           User?          @relation("DefendantCases", fields: [defendant_id], references: [id])
  pairing             Pairing        @relation(fields: [pairing_id], references: [id])
  plaintiff           User?          @relation("PlaintiffCases", fields: [plaintiff_id], references: [id])
  evidences           Evidence[]
  judgment            Judgment?
  quick_sessions      QuickSession[]
  case_content_links  CaseContentLink[]
  profile_snapshots   ProfileSnapshot[]

  @@index([pairing_id])
  @@index([plaintiff_id])
  @@index([defendant_id])
  @@index([status])
  @@index([type])
  @@index([created_at])
  @@index([submitted_at])
  @@index([mode])
  @@index([status, mode, created_at])
  @@map("cases")
}

model Evidence {
  id          String   @id @default(uuid())
  case_id     String
  user_id     String?
  file_url    String   @db.VarChar(500)
  mime_type   String?
  file_type   FileType
  file_size   Int
  checksum    String?
  description String?
  created_at  DateTime @default(now())

  case        Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [user_id], references: [id])

  @@index([case_id])
  @@index([user_id])
  @@index([file_type])
  @@map("evidences")
}

model Judgment {
  id                   String               @id @default(uuid())
  case_id              String               @unique
  judgment_content     String
  summary              String?
  plaintiff_ratio      Float
  defendant_ratio      Float
  emotional_analysis   Json?
  ai_model             String               @default("gpt-3.5-turbo") @db.VarChar(50)
  prompt_version       String               @default("v1.0") @db.VarChar(20)
  user1_acceptance     Boolean?
  user2_acceptance     Boolean?
  user1_rating         Int?
  user2_rating         Int?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  case                 Case                 @relation(fields: [case_id], references: [id], onDelete: Cascade)
  reconciliation_plans ReconciliationPlan[]

  @@index([case_id])
  @@index([created_at])
  @@index([user1_acceptance])
  @@index([user2_acceptance])
  @@map("judgments")
}

model ReconciliationPlan {
  id                 String            @id @default(uuid())
  judgment_id        String
  plan_content       String
  plan_type          PlanType
  difficulty_level   Difficulty
  estimated_duration Int?
  time_cost          Int
  money_cost         Int
  emotion_cost       Int
  skill_requirement  Int
  user1_selected     Boolean           @default(false)
  user2_selected     Boolean           @default(false)
  created_at         DateTime          @default(now())

  execution_records  ExecutionRecord[]
  judgment           Judgment          @relation(fields: [judgment_id], references: [id], onDelete: Cascade)

  @@index([judgment_id])
  @@index([difficulty_level])
  @@index([plan_type])
  @@map("reconciliation_plans")
}

model ExecutionRecord {
  id                     String             @id @default(uuid())
  reconciliation_plan_id String
  user_id                String
  action                 ExecutionAction
  status                 ExecutionStatus    @default(pending)
  notes                  String?
  photos_urls            String[]
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  reconciliation_plan    ReconciliationPlan @relation(fields: [reconciliation_plan_id], references: [id], onDelete: Cascade)
  user                   User               @relation(fields: [user_id], references: [id])

  @@index([reconciliation_plan_id])
  @@index([user_id])
  @@index([status])
  @@index([action])
  @@map("execution_records")
}

model QuickSession {
  id               String   @id @db.VarChar(100)
  pairing_id       String?
  case_id          String?
  session_data     Json?
  created_at       DateTime @default(now())
  expires_at       DateTime
  last_accessed_at DateTime @default(now())

  case             Case?    @relation(fields: [case_id], references: [id], onDelete: SetNull)
  pairing          Pairing? @relation(fields: [pairing_id], references: [id], onDelete: SetNull)

  @@index([expires_at])
  @@index([pairing_id])
  @@index([case_id])
  @@map("quick_sessions")
}

model EmailVerification {
  id         String            @id @default(uuid())
  email      String            @db.VarChar(255)
  code       String            @db.VarChar(6)
  type       VerificationType
  expires_at DateTime
  used       Boolean           @default(false)
  created_at DateTime          @default(now())

  @@index([email, type, used])
  @@index([code])
  @@index([expires_at])
  @@map("email_verifications")
}

model ContentItem {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(200)
  content     String
  content_type ContentType
  tags        String[]
  language    Language     @default(en)
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  case_links  CaseContentLink[]

  @@index([content_type])
  @@index([is_active])
  @@map("content_items")
}

model CaseContentLink {
  case_id    String
  content_id String
  relation   String    @default("recommend") @db.VarChar(30)
  created_at DateTime  @default(now())

  case       Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  content    ContentItem @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@id([case_id, content_id, relation])
  @@index([relation])
  @@map("case_content_links")
}

model Notification {
  id            String               @id @default(uuid())
  user_id       String
  channel       NotificationChannel
  template_code String               @db.VarChar(50)
  payload       Json?
  dedup_key     String?              @db.VarChar(100)
  sent_at       DateTime?
  status        NotificationStatus   @default(pending)
  error_message String?
  created_at    DateTime             @default(now())

  user          User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@unique([dedup_key, template_code])
  @@map("notifications")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actor_id    String?
  actor_type  String?  @db.VarChar(20)
  entity_type String?  @db.VarChar(50)
  entity_id   String?
  action      String?  @db.VarChar(50)
  detail      Json?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id, created_at])
  @@map("audit_logs")
}

// v2.0: 心理畫像系統模型

model InterviewSession {
  id               String           @id @default(uuid())
  user_id          String
  status           InterviewStatus  @default(in_progress)
  trigger          InterviewTrigger @default(organic)
  ai_model_used    String?          @db.VarChar(50)
  total_user_words Int              @default(0)
  total_ai_words   Int              @default(0)
  domains_touched  PsychDomain[]    @default([])
  collected_facts  String[]         @default([])
  feedback_card    String?
  pipeline_step    Int              @default(0)
  started_at       DateTime?
  ended_at         DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  turns            InterviewTurn[]

  // 每用戶僅 1 個 in_progress：需在遷移中以 raw SQL 建立部分唯一索引
  // CREATE UNIQUE INDEX ux_interview_sessions_user_in_progress ON interview_sessions(user_id) WHERE status = 'in_progress';
  @@index([user_id, status])
  @@index([user_id, created_at])
  @@index([status, updated_at])
  @@map("interview_sessions")
}

model InterviewTurn {
  id                 String        @id @default(uuid())
  session_id         String
  turn_order         Int
  ai_message         String
  ai_intent          String?
  ai_target_domains  PsychDomain[]   @default([])
  extracted_facts    String[]        @default([])
  user_response      String?
  skipped            Boolean       @default(false)
  safety_flag        Boolean       @default(false)
  safety_detail      String?
  response_word_count Int?
  created_at         DateTime      @default(now())

  session            InterviewSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([session_id, turn_order], name: "ux_interview_turns_session_order")
  @@map("interview_turns")
}

model ProfileNarrative {
  id              String      @id @default(uuid())
  user_id         String
  domain          PsychDomain
  raw_narrative   String
  ai_summary      String?
  word_count      Int         @default(0)
  // CHECK (completeness BETWEEN 0 AND 1) — 需在遷移中以 raw SQL 建立
  completeness    Float       @default(0)
  source_sessions String[]    @default([])
  is_latest       Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  insights        ProfileInsight[]

  @@index([user_id, domain, is_latest])
  // 每用戶每域僅 1 個 is_latest=true：需在遷移中以 raw SQL 建立部分唯一索引
  // CREATE UNIQUE INDEX ux_profile_narratives_user_domain_latest ON profile_narratives(user_id, domain) WHERE is_latest = true;
  @@map("profile_narratives")
}

model ProfileInsight {
  id            String      @id @default(uuid())
  user_id       String
  narrative_id  String?
  domain        PsychDomain
  insight_type  InsightType
  key           String      @db.VarChar(100)
  value         String
  // CHECK (confidence BETWEEN 0 AND 1) — 需在遷移中以 raw SQL 建立
  confidence    Float       @default(0.5)
  evidence      String?
  clinical_note String?
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  user          User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  narrative     ProfileNarrative? @relation(fields: [narrative_id], references: [id], onDelete: SetNull)

  @@index([user_id, domain, is_active])
  @@index([user_id, key, is_active])
  @@index([user_id, is_active, confidence])
  @@map("profile_insights")
}

model ProfileSnapshot {
  id              String   @id @default(uuid())
  user_id         String
  case_id         String
  snapshot_data   Json
  // CHECK (richness_score BETWEEN 0 AND 1) — 需在遷移中以 raw SQL 建立
  richness_score  Float    @default(0)
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  case            Case     @relation(fields: [case_id], references: [id], onDelete: Restrict)

  @@unique([case_id, user_id])
  @@index([user_id])
  @@map("profile_snapshots")
}
