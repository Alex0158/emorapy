{
  "name": "emorapy-root",
  "private": true,
  "version": "1.4.0",
  "workspaces": [
    "frontend",
    "frontend-admin",
    "packages/*"
  ],
  "scripts": {
    "contracts:build": "npm run build --workspace @emorapy/contracts",
    "api-client:build": "npm run build --workspace @emorapy/api-client",
    "vercel-build": "npm run contracts:build && npm run api-client:build && npm run build --workspace frontend-admin",
    "build": "npm run vercel-build",
    "docs:check": "npm run naming:check && npm run docs:check:structure && npm run docs:check:truth",
    "naming:check": "node scripts/check-emorapy-naming-governance.mjs",
    "docs:check:structure": "node scripts/check-docs-structure.mjs",
    "docs:check:truth": "node scripts/check-docs-truth.mjs",
    "docs:audit:dry-run": "node scripts/sync-core-docs-metadata.mjs --dry-run && node scripts/generate-core-docs-audit-ledger.mjs --dry-run",
    "docs:audit:dry-run:current": "node scripts/sync-core-docs-metadata.mjs --dry-run --current-only",
    "docs:audit:dry-run:non-current": "node scripts/sync-core-docs-metadata.mjs --dry-run --non-current-only",
    "docs:audit:sync": "node scripts/confirm-docs-audit-sync.mjs && node scripts/sync-core-docs-metadata.mjs && node scripts/generate-core-docs-audit-ledger.mjs",
    "web:a11y:contracts": "node scripts/check-web-a11y-contracts.mjs",
    "web:a11y:manual-evidence:template:check": "node scripts/check-web-a11y-manual-evidence.mjs --file docs/核心開發文件/90-證據與盤點/環境與發版驗證/Web-A11Y-Manual-Evidence-Template.json",
    "web:a11y:manual-evidence:check": "node scripts/check-web-a11y-manual-evidence.mjs --strict",
    "web:pending:completion:audit": "node scripts/check-web-pending-completion-audit.mjs",
    "web:pending:completion:audit:strict": "node scripts/check-web-pending-completion-audit.mjs --strict",
    "web:pending:completion:audit:contract": "node scripts/check-web-pending-completion-audit-contract.mjs",
    "web:admin-boundary:check": "node scripts/check-web-admin-boundary.mjs",
    "web:product-lines:check": "node scripts/check-web-product-lines-contracts.mjs",
    "dev:redis-baseline:check": "node scripts/check-dev-redis-baseline.mjs",
    "ai:positioning:check": "node scripts/check-ai-positioning-contracts.mjs",
    "manual-regression:init": "node scripts/init-manual-regression-batch.mjs",
    "manual-regression:check": "node scripts/check-manual-regression-status.mjs",
    "manual-regression:check:strict": "node scripts/check-manual-regression-status.mjs --require-evidence",
    "manual-regression:summarize": "node scripts/summarize-manual-regression.mjs",
    "manual-regression:mark": "node scripts/mark-manual-regression-result.mjs",
    "manual-regression:gate": "node scripts/run-manual-regression-gate.mjs",
    "ops:release:status": "bash scripts/ops-release-status.sh",
    "ops:release:smoke": "bash scripts/ops-release-smoke.sh",
    "ops:release:gate": "bash scripts/ops-release-gate.sh",
    "ops:release:gate:evidence": "bash scripts/ops-release-gate-evidence.sh",
    "web:p0:true-service:smoke": "npm --prefix backend run web:p0:true-service:smoke",
    "ops:db:status": "bash scripts/ops-db-status.sh"
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "jsdom": "^25.0.1",
    "playwright": "1.58.2"
  }
}
