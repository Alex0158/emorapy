# Emorapy - 後端環境變量配置示例
# 複製此文件為 .env 並填入實際值

# ============================================
# 服務器配置
# ============================================
# 服務器端口（默認: 3001，本地避免與前端衝突）
PORT=3001

# 運行環境: development | production | test
NODE_ENV=development

# ============================================
# 數據庫配置（必需）
# ============================================
# PostgreSQL 連接字符串
# 格式: postgresql://用戶名:密碼@主機:端口/數據庫名?參數
# 示例（Docker 開發）: postgresql://emorapy:emorapy_dev_pass@localhost:55432/emorapy_dev
DATABASE_URL=postgresql://emorapy:emorapy_dev_pass@localhost:55432/emorapy_dev

# 測試環境可選用 SQLite（降低依賴）
# TEST_USE_SQLITE=true
# TEST_SQLITE_URL=file:./tmp/test.db

# ============================================
# JWT 認證配置（必需）
# ============================================
# JWT 簽名密鑰（建議使用強隨機字符串，至少32字符）
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# JWT 過期時間（默認: 7d）
# 格式: 數字+單位 (如: 7d, 24h, 60m, 3600s)
JWT_EXPIRES_IN=7d

# 管理員 JWT 過期時間（默認: 12h；production / staging 需顯式配置）
# ADMIN_JWT_EXPIRES_IN=12h

# 管理員 JWT 獨立簽名密鑰（建議與 JWT_SECRET 不同；production / staging 必填）
# ADMIN_JWT_SECRET=your-admin-jwt-secret-change-in-production

# 首次管理員 bootstrap token（建議在生產環境設置）
# ADMIN_BOOTSTRAP_TOKEN=change-me-admin-bootstrap-token

# 可選：在 seed 階段建立低權限管理員（供 E2E 權限拒絕場景）
# LIMITED_ADMIN_SEED_EMAIL=limited-admin@example.com
# LIMITED_ADMIN_SEED_PASSWORD=ChangeMe1234
# LIMITED_ADMIN_SEED_NAME=Limited Admin
# LIMITED_ADMIN_SEED_ROLE=support

# ============================================
# OpenAI API 配置（必需）
# ============================================
# OpenAI API 密鑰（格式: sk-...）
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI 模型（默認: gpt-3.5-turbo）
OPENAI_MODEL=gpt-3.5-turbo

# 最大 Token 數（默認: 2000，範圍: 1-4000）
OPENAI_MAX_TOKENS=2000

# 每日調用限制（默認: 1000）
OPENAI_DAILY_LIMIT=1000

# ============================================
# 郵件服務配置（可選，推薦 Resend）
# ============================================
# 使用 Resend（https://resend.com）：免費 3000 封/月，SMTP 即插即用
# 1. 註冊 Resend → 驗證發信網域 → 創建 API Key
# 2. 填寫下方四項 + EMAIL_FROM（須為已驗證網域信箱）
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx
# 發件人信箱（Resend 必填：須為在 Resend 後台驗證過的網域，如 noreply@yourdomain.com）
# EMAIL_FROM=noreply@yourdomain.com

# 其他 SMTP（如 Gmail）可沿用以下格式，此時可不設 EMAIL_FROM（會用 SMTP_USER 當發件人）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

# ============================================
# 文件存儲配置
# ============================================
# 文件上傳目錄（默認: ./uploads）
UPLOAD_DIR=./uploads

# 最大文件大小（字節，默認: 5MB = 5242880）
MAX_FILE_SIZE=5242880

# CDN URL（生產環境，可選）
# CDN_URL=https://cdn.yourdomain.com

# ============================================
# 前端配置
# ============================================
# 前端 URL（用於 CORS 和重定向）
# 開發環境: http://localhost:5173
# 生產環境: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# 文件訪問基礎 URL（用於返回上傳文件的可訪問地址，默認同 PORT）
FILE_BASE_URL=http://localhost:3001

# 允許的來源（CORS，多個用逗號分隔，無尾斜線）
# 開發環境: http://localhost:5173
# 生產環境（Vercel 前台）必須包含實際前台網域，否則 Quick Experience 等會 CORS 403
# 例（Railway 後端對接 Vercel）: ALLOWED_ORIGINS=https://emorapy.vercel.app
# 例（多網域）: ALLOWED_ORIGINS=https://emorapy.vercel.app,https://emorapy-admin.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# 可選：上傳訪問 IP 黑名單（逗號分隔，精確匹配 req.ip）
# BLACKLIST_IPS=

# ============================================
# 數據庫遷移配置（可選）
# ============================================
# 是否自動運行遷移（默認: true）
# 設置為 false 可禁用自動遷移
# RUN_MIGRATIONS=true

# ============================================
# 其他開關（布林值請僅用 true/false 小寫）
# ============================================
# 允許公共上傳（僅限開發/測試，生產會被強制禁用）
# ALLOW_PUBLIC_UPLOADS=false
# 公共上傳允許路徑（當 ALLOW_PUBLIC_UPLOADS=true 時，逗號分隔）
# PUBLIC_UPLOAD_PATHS=/uploads,/files
# 允許降級為簡單鎖（無 Redis）
# ALLOW_SIMPLE_LOCK=false
# 跳過 DB 初始化（僅供測試流程）
# SKIP_DB_INIT=false
# 跳過速率限制（僅開發環境）
# SKIP_RATE_LIMIT=false
# 啟用定時任務（默認: 生產環境自動啟用）
# ENABLE_SCHEDULED_JOBS=true
# 使用 Mock AI（無需 OpenAI API，開發/測試用）
# AI_MOCK=false

# ============================================
# 🧠 v2.0 心理畫像與 AI 訪談配置（可選）
# ============================================
# 訪談對話模型（默認: gpt-4o-mini）
# OPENAI_INTERVIEW_MODEL=gpt-4o-mini

# 分析/摘要/洞察提取模型（默認: gpt-4o）
# OPENAI_ANALYSIS_MODEL=gpt-4o

# 每次訪談最大輪數（硬限，默認: 25）
# INTERVIEW_MAX_TURNS=25

# AI 建議結束的軟目標輪數（默認: 15）
# INTERVIEW_SOFT_TARGET=15

# 每輪最小間隔毫秒（防刷，默認: 3000）
# INTERVIEW_TURN_INTERVAL_MS=3000

# start 端點每用戶每小時最多請求數（express-rate-limit 中間件，防濫用，不計 turn 數；默認: 3）
# INTERVIEW_START_RATE_LIMIT=3

# 每用戶每天最多 substantive session 數（業務邏輯，僅計 ≥ 3 輪的 session；默認: 5）
# INTERVIEW_DAILY_SESSION_LIMIT=5

# ============================================
# Redis 配置（本地開發推薦啟用；production / staging 必須配置並通過 release gate）
# ============================================
# 本地默認建議使用 docker compose 啟動：
#   npm run dev:redis:up
# 如本機已有 Redis 或端口衝突，可自行調整 URL 與 compose 端口
# REDIS_URL=redis://127.0.0.1:6379
# AI Stream runtime 會在有 REDIS_URL 時自動啟用：
# - 跨實例 stream 事件分發（Pub/Sub）
# - 短期 replay 事件緩衝
# - 短期 snapshot 同步
# 未配置 REDIS_URL 時，AI Stream 會降級為單機內存模式；僅允許本機開發 / test。
# staging / production 的 ops:release:gate 會要求 REDIS_URL、禁止 ALLOW_SIMPLE_LOCK=true，
# 並解析 /health，確認 lock 與 AI Stream backend 都是 redis。
# staging 若暫未掛 Redis，需顯式同時配置並記入例外風險；正式 release gate 仍會阻斷：
# ALLOW_SIMPLE_LOCK=true
# METRICS_ENABLED=false
# 並接受 /health 顯示 lock degraded
# AI Stream 持久化治理
# AI_STREAM_SESSION_RETENTION_DAYS=30
# AI_STREAM_EVENT_RETENTION_DAYS=14
# AI_STREAM_ARCHIVE_ENABLED=true
# AI_STREAM_ARCHIVE_BATCH_SIZE=500
# 真實 Redis 多實例整合驗證（測試/CI 專用）
# TEST_REDIS_URL=redis://localhost:6379

# ============================================
# Ops 告警（可選）
# ============================================
# 用於 ops:alerts:check 與定時告警任務
# OPS_ALERTS_API_BASE_URL=http://127.0.0.1:3001
# OPS_ALERTS_HEALTH_TIMEOUT_MS=5000
# OPS_ALERTS_LOOKBACK_MINUTES=15
# OPS_ALERTS_MIN_SAMPLES=30
# OPS_ALERTS_MAX_5XX_RATIO=0.05
# OPS_ALERTS_MAX_CONFLICT_RATIO=0.2
# ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# ALERT_SLACK_DEDUP_WINDOW_SECONDS=600
# ALERT_HEALTH_ORIGIN=https://your-frontend-domain.com

# ============================================
# Metrics 暴露保護（建議）
# ============================================
# 是否啟用 /metrics（默認 true；production / staging 建議保持 true）
# METRICS_ENABLED=true
# 線上環境建議至少配置其一：
# 1) Header Token（抓取端需帶 X-Metrics-Token）
# METRICS_TOKEN=replace-with-strong-random-token
# 2) 允許抓取的來源 IP（逗號分隔，精確匹配 req.ip）
# METRICS_ALLOWED_IPS=127.0.0.1,10.0.0.5

# ============================================
# 成本監控外部 API（可選）
# ============================================
# Railway egress 成本資料（/admin/reports/costs）
# RAILWAY_API_TOKEN=
# RAILWAY_PROJECT_ID=
# RAILWAY_ENVIRONMENT_ID=
#
# OpenAI usage/cost（/admin/reports/costs）
# OPENAI_BILLING_API_KEY=
# OPENAI_ORG_ID=
# AI request ledger request-level cost attribution（release gate 會要求覆蓋 OPENAI_MODEL / OPENAI_INTERVIEW_MODEL / OPENAI_ANALYSIS_MODEL；價格需由運維按當前供應商價格明確配置，不要使用過期硬編碼）
# AI_COST_PRICING_JSON={"source":"manual-openai-pricing","version":"YYYY-MM-DD","models":{"gpt-3.5-turbo":{"inputUsdPer1M":0,"outputUsdPer1M":0},"gpt-4o-mini":{"inputUsdPer1M":0,"outputUsdPer1M":0},"gpt-4o":{"inputUsdPer1M":0,"outputUsdPer1M":0}}}
# AI_COST_REQUIRED_MODELS=gpt-4.1
# AI_COST_PRICING_MAX_AGE_DAYS=30

# ============================================
# 數據庫連線調優（可選）
# ============================================
# 連線超時毫秒（默認: 10000）
# DB_CONNECT_TIMEOUT=10000
# 重試間隔毫秒（默認: 3000）
# DB_RETRY_INTERVAL=3000
# 最大重試次數（默認: 3）
# DB_MAX_RETRIES=3

# ============================================
# 緩存與鎖調優（可選）
# ============================================
# 內存緩存最大條目數（默認: 1000）
# CACHE_MAX_SIZE=1000
# 緩存清理間隔毫秒（默認: 300000）
# CACHE_CLEANUP_INTERVAL_MS=300000
# 鎖清理間隔毫秒（默認: 60000）
# LOCK_CLEANUP_INTERVAL_MS=60000

# ============================================
# 判決服務調優（可選）
# ============================================
# 判決重試冷卻時間毫秒（默認: 60000）
# JUDGMENT_RETRY_COOLDOWN_MS=60000
# 是否啟用心理畫像上下文注入（默認: true；設為 false 可快速回退）
# JUDGMENT_ENABLE_PROFILE_CONTEXT=true
# 是否啟用案件上下文注入（默認: true；設為 false 可快速回退）
# JUDGMENT_ENABLE_CASE_CONTEXT=true
# 判決注入上下文是否要求 psych_consent_given（默認: true）
# JUDGMENT_PROFILE_REQUIRE_CONSENT=true
# 個人化畫像上下文的最長回看天數（默認: 365）
# JUDGMENT_PROFILE_MAX_AGE_DAYS=365
# 是否在日志中輸出 context governance 審計欄位（默認: true）
# JUDGMENT_CONTEXT_AUDIT_ENABLED=true

# ============================================
# Chat 並發壓測與 migration 演練（可選）
# ============================================
# 壓測 API 入口（可用 LB / API Gateway URL）
# API_BASE_URL=http://localhost:3001/api/v1
# 併發突發量
# BURST_SIZE=20
# 請求超時（毫秒）
# REQUEST_TIMEOUT_MS=15000
# 判決壓測輪詢次數 / 間隔
# STATUS_POLL_TIMES=15
# STATUS_POLL_INTERVAL_MS=1000
# 判決壓測身份（擇一）
# AUTH_TOKEN=
# SESSION_ID=
# 邀請接受壓測身份
# OWNER_AUTH_TOKEN=
# INVITEE_TOKENS=tokenA,tokenB,tokenC
# Gate 控制
# GATE_RUN_JUDGMENT=true
# GATE_RUN_INVITE_ACCEPT=true
# GATE_REPORT_DIR=./tmp/bench-reports
# GATE_REPORT_PATH=./tmp/bench-reports/chat-concurrency-gate-report.json
# Migration 預檢/修復留檔
# PRECHECK_REPORT_PATH=./tmp/bench-reports/chat-active-roles-precheck.json
# FIX_PLAN_OUTPUT_PATH=./tmp/bench-reports/chat-active-roles-fix-plan.sql
# FIX_PLAN_REPORT_PATH=./tmp/bench-reports/chat-active-roles-fix-plan.json
# 允許的頭像域名（逗號分隔，默認: FILE_BASE_URL + CDN_URL 的域名）
# ALLOWED_AVATAR_HOSTS=

# ============================================
# 日誌配置（可選）
# ============================================
# 日誌級別: error | warn | info | debug
# 開發環境建議: debug
# 生產環境建議: info
# LOG_LEVEL=debug
